<%#
# Form Partial

This partial is rendered on a resource's `new` and `edit` pages,
and renders all form fields for a resource's editable attributes.

## Local variables:

- `page`:
  An instance of [Administrate::Page::Form][1].
  Contains helper methods to display a form,
  and knows which attributes should be displayed in the resource's form.

[1]: http://www.rubydoc.info/gems/administrate/Administrate/Page/Form
%>

<%= form_with(model: page.resource, url: [namespace, page.resource], scope: page.resource, local: true, class: "form", data: { controller: "administrate-task-ui-add-arg-inputs", "administrate-task-ui-add-arg-inputs-available-tasks-value" => ::Administrate::Task::Ui::TaskFormatter.available_tasks_hash }) do |f| %>
  <% if page.resource.errors.any? %>
    <div id="error_explanation">
      <h2>
        <%= t(
          "administrate.form.errors",
          pluralized_errors: pluralize(page.resource.errors.count, t("administrate.form.error")),
          resource_name: display_resource_name(page.resource_name, singular: true)
        ) %>
      </h2>

      <ul>
        <% page.resource.errors.full_messages.each do |message| %>
          <li class="flash-error"><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% page.attributes(controller.action_name).each do |title, attributes| -%>
    <fieldset class="<%= "field-unit--nested" if title.present? %>">
      <% if title.present? %>
        <legend><%= t "helpers.label.#{f.object_name}.#{title}", default: title %></legend>
      <% end %>

      <% attributes.each do |attribute| %>
        <div class="field-unit field-unit--<%= attribute.html_class %> field-unit--<%= requireness(attribute) %>">
          <%= render_field attribute, f: f %>

          <% hint_key = "administrate.field_hints.#{page.resource_name}.#{attribute.name}" %>
          <% if I18n.exists?(hint_key) -%>
            <div class="field-unit__hint">
              <%= I18n.t(hint_key) %>
            </div>
          <% end -%>
        </div>

        <div data-administrate-task-ui-add-arg-inputs-target="inputContainer"></div>
      <% end %>
    </fieldset>
  <% end -%>

  <div class="form-actions administrate-task-ui flex gap-2">
    <div
      data-controller="administrate-task-ui-view-source-code"
      data-administrate-task-ui-view-source-code-url-value="<%= source_code_admin_task_runs_url %>"
    >
      <button class="button--alt" command="show-modal" commandfor="administrate-task-ui-source-code-dialog" type="button" data-action="administrate-task-ui-view-source-code#loadSourceCode">View Source Code</button>

      <dialog id="administrate-task-ui-source-code-dialog" closedby="any">
       <h2>Source Code</h2>
        <code>
          <pre data-administrate-task-ui-view-source-code-target="sourceCode">
            loading...
          </pre>
        </code>
      </dialog>
    </div>

    <%= f.submit %>
  </div>
<% end %>
